# PostgreSQL
DATABASE_URL=postgresql://user:password@server-ip:5432/editor_metadatos

# SFTP Storage Server
SFTP_HOST=server-ip
SFTP_PORT=22
SFTP_USER=sftp_user
SFTP_PASSWORD=sftp_password

# Remote base path for photos on the SFTP server
SFTP_BASE_PATH=/fotos

# WordPress Configuration (Optional)
# You can also configure this in the app UI

# Your WordPress site URL (without trailing slash)
NEXT_PUBLIC_WP_SITE_URL=https://yoursite.com

# Your WordPress username
NEXT_PUBLIC_WP_USERNAME=admin

# Application Password (create in WP Admin -> Users -> Application Passwords)
# Format: xxxx xxxx xxxx xxxx xxxx xxxx
NEXT_PUBLIC_WP_APP_PASSWORD=
