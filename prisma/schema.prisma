generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Users ──────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(320)
  firstName String   @map("first_name") @db.VarChar(255)
  lastName  String   @map("last_name") @db.VarChar(255)
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fotografo Fotografo?

  @@map("users")
}

// ─── Fotografos ────────────────────────────────────────────────────────────

model Fotografo {
  id        String   @id @default(uuid()) @db.Uuid
  firstName String   @map("first_name") @db.VarChar(255)
  lastName  String   @map("last_name") @db.VarChar(255)
  email     String?  @unique @db.VarChar(320)
  userId    String?  @unique @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  albums Album[]

  @@index([email])
  @@map("fotografos")
}

// ─── Albums ────────────────────────────────────────────────────────────────

model Album {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  photographer   String?  @db.VarChar(255) // Legacy — will be removed after data migration
  photographerId String?  @map("photographer_id") @db.Uuid
  eventDate      DateTime @map("event_date") @db.Date
  city           String?  @db.VarChar(255)
  state          String?  @db.VarChar(255)
  country        String?  @db.VarChar(255)
  keywords       String[] @default([])
  colorTags      String[] @default([]) @map("color_tags")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  fotografo Fotografo? @relation(fields: [photographerId], references: [id], onDelete: SetNull)
  photos    Photo[]

  @@index([photographerId])
  @@index([city, country])
  @@index([eventDate])
  @@index([keywords], type: Gin)
  @@index([colorTags], type: Gin)
  @@map("albums")
}

model Photo {
  id               String   @id @default(uuid()) @db.Uuid
  albumId          String   @map("album_id") @db.Uuid
  originalFilename String   @map("original_filename") @db.VarChar(500)
  storedFilename   String   @map("stored_filename") @db.VarChar(500)
  storedPath       String   @map("stored_path") @db.VarChar(1000)
  thumbnailPath    String?  @map("thumbnail_path") @db.VarChar(1000)
  mediaType        String   @default("photo") @map("media_type") @db.VarChar(20)
  fileSize         Int      @map("file_size")
  width            Int?
  height           Int?
  title            String?  @db.VarChar(500)
  description      String?  @db.Text
  keywords         String[] @default([])
  copyright        String?  @db.VarChar(500)
  artist           String?  @db.VarChar(255)
  dateCreated      String?  @map("date_created") @db.VarChar(100)
  city             String?  @db.VarChar(255)
  state            String?  @db.VarChar(255)
  country          String?  @db.VarChar(255)
  gpsLatitude      Float?   @map("gps_latitude")
  gpsLongitude     Float?   @map("gps_longitude")
  cameraMake       String?  @map("camera_make") @db.VarChar(255)
  cameraModel      String?  @map("camera_model") @db.VarChar(255)
  colorTags        String[] @default([]) @map("color_tags")
  createdAt        DateTime @default(now()) @map("created_at")

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
  @@index([keywords], type: Gin)
  @@index([colorTags], type: Gin)
  @@index([artist])
  @@index([city, country])
  @@map("photos")
}
